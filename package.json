{
  "name": "basominang",
  "version": "1.0.0",
  "description": "Compiler untuk bahasa pemrograman BasoMinang.",
  "private": true,
  "type": "commonjs",
  "main": "index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "build": "npm run build:basominang && npm run build:bm",
    "build:basominang": "pkg index.js --targets node18-win-x64 --output dist/basominang.exe",
    "build:bm": "pkg index.js --targets node18-win-x64 --output dist/bm.exe",
    "installer": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1"
  },
  "bin": {
    "basominang": "index.js",
    "bm": "index.js"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "ora": "^5.4.1",
    "readline-sync": "^1.4.10"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ]
  }
}
