{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "BasoMinang",
  "scopeName": "source.bm",
  "fileTypes": [".bm"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords_declaration" },
    { "include": "#keywords_control" },
    { "include": "#keywords_logical" },
    { "include": "#booleans" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function_calls" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "name": "comment.block.basominang",
      "begin": "-\\{jan dibaco:",
      "end": "\\}-",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.basominang" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.basominang" }
      }
    },
    "keywords_declaration": {
      "comment": "Keyword deklarasi variabel, konstanta, fungsi",
      "name": "keyword.declaration.basominang",
      "match": "\\b(buek|tapek|karajo)\\b"
    },
    "keywords_control": {
      "comment": "Keyword kontrol alur program",
      "name": "keyword.control.basominang",
      "match": "\\b(jiko|lain|salamo|untuak|baliakan|baranti|lanjuik|cetak)\\b"
    },
    "keywords_logical": {
      "comment": "Operator logika dalam bentuk kata",
      "name": "keyword.operator.logical.basominang",
      "match": "\\b(jo|atau|indak)\\b"
    },
    "booleans": {
      "comment": "Nilai boolean, null, undefined",
      "name": "constant.language.basominang",
      "match": "\\b(batua|salah|kosong|datantu)\\b"
    },
    "strings": {
      "name": "string.quoted.single.basominang",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.basominang",
          "match": "\\\\(n|t|r|'|\\\\)"
        }
      ]
    },
    "numbers": {
      "comment": "Angka integer dan float",
      "name": "constant.numeric.basominang",
      "match": "\\b([0-9]+\\.?[0-9]*)\\b"
    },
    "operators": {
      "comment": "Operator aritmatika, perbandingan, assignment",
      "patterns": [
        {
          "name": "keyword.operator.comparison.basominang",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.basominang",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.increment.basominang",
          "match": "(\\+\\+|--)"
        },
        {
          "name": "keyword.operator.arithmetic.basominang",
          "match": "([+\\-*/%])"
        }
      ]
    },
    "function_calls": {
      "comment": "Nama fungsi saat dipanggil",
      "name": "entity.name.function.basominang",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
    },
    "identifiers": {
      "comment": "Nama variabel dan identifier lainnya",
      "name": "variable.other.basominang",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
