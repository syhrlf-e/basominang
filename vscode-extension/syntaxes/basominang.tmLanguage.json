{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "BasoMinang",
  "scopeName": "source.basominang",
  "fileTypes": ["bm"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords_declaration" },
    { "include": "#keywords_control" },
    { "include": "#keywords_logical" },
    { "include": "#constants" },
    { "include": "#templates" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function_calls" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "name": "comment.block.basominang",
      "begin": "-\\{jan dibaco:",
      "end": "\\}-",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.basominang" } },
      "endCaptures": { "0": { "name": "punctuation.definition.comment.end.basominang" } }
    },
    "keywords_declaration": {
      "name": "keyword.declaration.basominang",
      "match": "\\b(buek|tapek|karajo)\\b"
    },
    "keywords_control": {
      "name": "keyword.control.basominang",
      "match": "\\b(jiko|lain|salamo|untuak|baliakan|baranti|lanjuik|cetak)\\b"
    },
    "keywords_logical": {
      "name": "keyword.operator.logical.basominang",
      "match": "\\b(jo|atau|indak)\\b"
    },
    "constants": {
      "name": "constant.language.basominang",
      "match": "\\b(batua|salah|kosong|datantu)\\b"
    },
    "templates": {
      "name": "string.quoted.other.template.basominang",
      "begin": "`",
      "end": "`",
      "patterns": [
        { "name": "constant.character.escape.basominang", "match": "\\\\(n|t|r|`|\\\\|\\$)" },
        {
          "name": "meta.interpolation.basominang",
          "begin": "\\$\\{",
          "end": "\\}",
          "patterns": [
            { "include": "#keywords_logical" },
            { "include": "#constants" },
            { "include": "#numbers" },
            { "include": "#function_calls" }
          ]
        }
      ]
    },
    "strings": {
      "name": "string.quoted.single.basominang",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "name": "constant.character.escape.basominang", "match": "\\\\(n|t|r|'|\\\\)" }
      ]
    },
    "numbers": {
      "name": "constant.numeric.basominang",
      "match": "\\b([0-9]+\\.?[0-9]*)\\b"
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.basominang", "match": "(==|!=|<=|>=|<|>)" },
        { "name": "keyword.operator.assignment.basominang", "match": "(\\+=|-=|\\*=|/=|=)" },
        { "name": "keyword.operator.increment.basominang", "match": "(\\+\\+|--)" },
        { "name": "keyword.operator.arithmetic.basominang", "match": "([+\\-*/%])" }
      ]
    },
    "function_calls": {
      "name": "entity.name.function.basominang",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
    },
    "identifiers": {
      "name": "variable.other.basominang",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
