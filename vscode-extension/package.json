{
  "name": "basominang",
  "displayName": "BasoMinang",
  "description": "Syntax highlighting untuk bahasa pemrograman BasoMinang (.bm)",
  "version": "1.0.1",
  "publisher": "basominang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/syhrlf-e/basominang"
  },
  "contributes": {
    "languages": [
      {
        "id": "basominang",
        "aliases": ["BasoMinang", "bm"],
        "extensions": [".bm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "basominang",
        "scopeName": "source.basominang",
        "path": "./syntaxes/basominang.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "basominang-file-icons",
        "label": "BasoMinang File Icons",
        "path": "./icons/basominang-icon-theme.json"
      }
    ]
  }
}
